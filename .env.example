# Convex
# Convex deployment name
CONVEX_DEPLOYMENT=
# Convex deployment URL (required)
VITE_CONVEX_URL=

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
# Generer avec : pnpm dlx @better-auth/cli secret
BETTER_AUTH_SECRET=

# Sanity CMS (projet existant : 8zuvflol)
VITE_SANITY_PROJECT_ID=8zuvflol
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2026-05-01
# Token d'ecriture (seed/admin) — Manage > API > Tokens > Editor. SERVEUR uniquement (pas de prefixe VITE_).
SANITY_WRITE_TOKEN=
# Token de lecture (SSR sur dataset prive) — role Viewer. Sert de readToken en prod (cf. src/lib/cms/client.ts).
# Si absent, le code retombe sur SANITY_WRITE_TOKEN.
SANITY_API_READ_TOKEN=

# Brevo (capture de leads + newsletter) — SERVEUR uniquement (pas de prefixe VITE_).
# Tant que BREVO_API_KEY est vide, les formulaires fonctionnent mais n'envoient rien (no-op).
# Cle : Brevo > SMTP & API > API Keys.
BREVO_API_KEY=
# ID numerique de la liste newsletter : Brevo > Contacts > Lists.
BREVO_LIST_ID=
# Destinataire des notifications de demandes (boite d'Emeline).
LEAD_NOTIFY_EMAIL=contact@precieuse-joaillerie.com
# Expediteur verifie cote Brevo (Senders & IP).
LEAD_FROM_EMAIL=contact@precieuse-joaillerie.com
